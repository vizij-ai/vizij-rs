{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "strict": true,
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "types": ["node"],
    "paths": {
      "@vizij/wasm-loader": ["npm/@vizij/wasm-loader/src/index.ts"],
      "@vizij/wasm-loader/browser": ["npm/@vizij/wasm-loader/src/browser.ts"],
      "@vizij/wasm-loader/shared": ["npm/@vizij/wasm-loader/src/shared.ts"]
    }
  },
  "include": ["npm/@vizij/*/src/**/*.ts"]
}
