#!/usr/bin/env bash
set -eu

if ! command -v pnpm >/dev/null 2>&1; then
  echo "[pre-push] pnpm not found; skipping checks"
  exit 0
fi

if ! command -v cargo >/dev/null 2>&1; then
  echo "[pre-push] cargo not found; skipping checks"
  exit 0
fi

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$REPO_ROOT"
pnpm run hook:pre-push
