#!/usr/bin/env bash
# Skip hooks on Windows / WSL (GitHub Desktop may invoke hooks via WSL where cargo is unavailable)
case "$(uname -s 2>/dev/null)" in MINGW*|MSYS*|CYGWIN*) exit 0 ;; esac
if grep -qi microsoft /proc/version 2>/dev/null; then exit 0; fi
set -eu
REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$REPO_ROOT"
pnpm run hook:pre-commit
