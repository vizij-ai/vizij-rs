{
  "name": "@vizij/animation-module",
  "version": "0.3.0",
  "description": "vizij-animation-core packaged as an Arora wasm module: the built artifact (wasm + header) as importable assets.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vizij-ai/vizij-rs"
  },
  "homepage": "https://github.com/vizij-ai/vizij-rs",
  "bugs": {
    "url": "https://github.com/vizij-ai/vizij-rs/issues"
  },
  "keywords": [
    "vizij",
    "arora",
    "animation",
    "wasm",
    "webassembly"
  ],
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/browser.js",
  "types": "dist/index.d.ts",
  "browser": {
    "./dist/index.js": "./dist/browser.js"
  },
  "files": [
    "dist/",
    "artifact/",
    "README.md"
  ],
  "exports": {
    ".": {
      "browser": {
        "types": "./dist/browser.d.ts",
        "import": "./dist/browser.js",
        "default": "./dist/browser.js"
      },
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "node scripts/build-artifact.mjs && tsc -p tsconfig.json",
    "test": "pnpm run build && node tests/smoke.mjs",
    "clean": "rm -rf dist artifact",
    "prepack": "pnpm run build"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "@types/node": "^20.12.7",
    "yaml": "^2.5.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
