{
  "name": "@vizij/test-fixtures",
  "version": "0.0.1",
  "private": true,
  "description": "Shared test fixtures for Vizij Rust + npm packages.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/"
  ],
  "exports": {
    ".": {
      "browser": "./dist/index.browser.js",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./shared/browser": {
      "browser": "./dist/shared.browser.js",
      "import": "./dist/shared.browser.js",
      "default": "./dist/shared.browser.js"
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "node scripts/generate-browser-fixtures.mjs && tsc -p tsconfig.json",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "@types/node": "^20.12.7"
  }
}
