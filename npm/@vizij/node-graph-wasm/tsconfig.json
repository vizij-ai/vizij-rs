{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "declaration": true,
    "outDir": "dist",
    "strict": true,
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "types": ["node"],
    "paths": {
      "@vizij/wasm-loader": ["../wasm-loader/src/index.ts"],
      "@vizij/wasm-loader/browser": ["../wasm-loader/src/browser.ts"],
      "@vizij/wasm-loader/shared": ["../wasm-loader/src/shared.ts"]
    }
  },
  "include": ["src", "tests"]
}
