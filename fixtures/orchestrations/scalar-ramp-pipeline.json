{
  "description": "Scalar ramp animation drives a gain/offset graph",
  "schedule": "SinglePass",
  "animations": [
    {
      "fixture": "simple-scalar-ramp",
      "id": "scalar-ramp",
      "player": {
        "name": "fixture-player",
        "loop_mode": "once"
      }
    }
  ],
  "graphs": [
    {
      "fixture": "simple-gain-offset",
      "id": "gain-offset"
    }
  ],
  "initial_inputs": [
    {
      "path": "demo/graph/gain",
      "value": 1.5
    },
    {
      "path": "demo/graph/offset",
      "value": 0.25
    }
  ],
  "steps": [
    {
      "delta": 0.0,
      "expect": {
        "node.t": 0.0,
        "demo/output/value": 0.25
      }
    },
    {
      "delta": 0.5,
      "expect": {
        "node.t": 0.5,
        "demo/output/value": 1.0
      }
    },
    {
      "delta": 1.0,
      "expect": {
        "node.t": 1.0,
        "demo/output/value": 1.75
      }
    }
  ]
}
